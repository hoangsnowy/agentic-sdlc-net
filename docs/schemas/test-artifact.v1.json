{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentic-sdlc/schemas/test-artifact.v1.json",
  "title": "TestArtifact v1",
  "type": "object",
  "required": ["files", "happyPathCount", "edgeCaseCount", "errorCaseCount"],
  "additionalProperties": true,
  "properties": {
    "framework": { "type": "string" },
    "files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["path", "content"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "content": { "type": "string" },
          "language": { "type": "string" }
        }
      }
    },
    "happyPathCount": { "type": "integer", "minimum": 0 },
    "edgeCaseCount": { "type": "integer", "minimum": 0 },
    "errorCaseCount": { "type": "integer", "minimum": 0 },
    "estimatedCoveragePercent": { "type": "integer", "minimum": 0, "maximum": 100 }
  }
}
