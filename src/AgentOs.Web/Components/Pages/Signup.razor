@page "/signup"
@layout AuthLayout
@attribute [AllowAnonymous]
@using AgentOs.Modules.Tenants
@inject AgentOs.Modules.Tenants.ITenantSignupService SignupSvc
@inject NavigationManager Nav

<PageTitle>Create workspace — AgentOS</PageTitle>

<div class="login-card login-card-wide">
    <div class="login-brand">
        <div class="brand-mark"><Icon Name="diamond" Size="14" /></div>
        <div>
            <div class="brand-title">@(_invitePreview is null ? "Create workspace" : "Join workspace")</div>
            <div class="brand-sub">
                @(_invitePreview is null
                    ? "Provision a tenant + admin user"
                    : $"You were invited to '{_invitePreview.TenantId}' as {_invitePreview.Role}")
            </div>
        </div>
    </div>

    <div class="login-form">
        @if (_invitePreview is null)
        {
            <Field Label="Workspace ID" Hint="leave blank to auto-generate · or pick lowercase / digits / dash · 1–32 chars">
                <input type="text" @bind="_tenantId" placeholder="acme (optional)" autocomplete="off" />
            </Field>
            <Field Label="Workspace name (optional)">
                <input type="text" @bind="_tenantName" placeholder="Acme Corp" autocomplete="organization" />
            </Field>
        }
        <Field Label="@(_invitePreview is null ? "Admin username" : "Username")">
            <input type="text" @bind="_username" placeholder="alice" autocomplete="username" />
        </Field>
        <Field Label="Email">
            <input type="email" @bind="_email" placeholder="alice@@acme.test" autocomplete="email" />
        </Field>
        <Field Label="Password" Hint="at least 12 chars · upper + lower + digit + symbol">
            <input type="password" @bind="_password" autocomplete="new-password" />
        </Field>
        <Field Label="Confirm password">
            <input type="password" @bind="_confirm" autocomplete="new-password" />
        </Field>
        <Btn Variant="Btn.ButtonVariant.Primary" ExtraClass="login-btn" OnClick="Submit" Disabled="_busy">
            @(_busy ? "Submitting…" : _invitePreview is null ? "Create workspace" : "Join workspace")
        </Btn>
        @if (!string.IsNullOrEmpty(_error))
        {
            <div class="login-error">@_error</div>
        }
        <div class="login-hint">
            Already have an account? <a href="/login">Sign in</a>
        </div>
    </div>
</div>

@code {
    [SupplyParameterFromQuery(Name = "invite")] public string? InviteToken { get; set; }

    private string _tenantId = "";
    private string _tenantName = "";
    private string _username = "";
    private string _email = "";
    private string _password = "";
    private string _confirm = "";
    private string _error = "";
    private bool _busy;
    private InvitationPreview? _invitePreview;

    protected override void OnParametersSet()
    {
        _invitePreview = string.IsNullOrWhiteSpace(InviteToken) ? null : SignupSvc.PreviewInvitation(InviteToken);
        if (_invitePreview is not null && string.IsNullOrEmpty(_email) && !string.IsNullOrEmpty(_invitePreview.Email))
        {
            _email = _invitePreview.Email;
        }
    }

    private async Task Submit()
    {
        if (_busy) { return; }
        _busy = true;
        _error = "";
        try
        {
            if (!string.Equals(_password, _confirm, StringComparison.Ordinal))
            {
                _error = "Passwords do not match.";
                return;
            }

            try
            {
                await SignupSvc.SignupAsync(new TenantSignupRequest(
                    Username: _username,
                    Password: _password,
                    Email: string.IsNullOrWhiteSpace(_email) ? null : _email,
                    TenantId: string.IsNullOrWhiteSpace(_tenantId) ? null : _tenantId,
                    TenantName: string.IsNullOrWhiteSpace(_tenantName) ? null : _tenantName,
                    InviteToken: InviteToken));
            }
            catch (InvalidOperationException ex)
            {
                _error = ex.Message;
                return;
            }

            Nav.NavigateTo("/signup/verify-email", forceLoad: false);
        }
        finally
        {
            _busy = false;
        }
    }
}
