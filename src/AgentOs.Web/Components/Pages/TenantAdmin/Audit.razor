@page "/admin/audit"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "admin")]
@using AgentOs.Modules.Tenants
@inject AgentOs.SharedKernel.Identity.ITenantContext Ctx
@inject AgentOs.Modules.Tenants.IAuditLog AuditSvc

<PageTitle>Audit — @Ctx.TenantId</PageTitle>

<div class="admin-page">
    <header class="admin-head">
        <h1>Audit · <code>@Ctx.TenantId</code></h1>
        <p class="admin-sub">Newest first · @(_entries?.Count ?? 0) entries · best-effort writes</p>
    </header>

    @if (_entries is null)
    {
        <Spinner />
    }
    else if (_entries.Count == 0)
    {
        <p class="admin-sub">No audit events recorded yet.</p>
    }
    else
    {
        <table class="admin-tbl">
            <thead>
                <tr>
                    <th>When (UTC)</th>
                    <th>Action</th>
                    <th>User</th>
                    <th>Target</th>
                    <th>IP</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var e in _entries)
                {
                    <tr>
                        <td>@e.TimestampUtc.ToString("u")</td>
                        <td><code>@e.Action</code></td>
                        <td>@(e.UserId ?? "—")</td>
                        <td>@(e.Target ?? "—")</td>
                        <td>@(e.IpAddress ?? "—")</td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@code {
    private IReadOnlyList<AuditEntry>? _entries;

    protected override async Task OnInitializedAsync()
    {
        _entries = await AuditSvc.ListAsync(Ctx.TenantId, max: 200);
    }
}
