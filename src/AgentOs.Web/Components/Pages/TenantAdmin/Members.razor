@page "/admin/members"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "admin")]
@using AgentOs.Modules.Tenants
@using AgentOs.Modules.Tenants.Keycloak
@using AgentOs.SharedKernel.Identity
@inject AgentOs.SharedKernel.Identity.ITenantContext Ctx
@inject AgentOs.Modules.Tenants.Keycloak.IKeycloakAdminClient Kc
@inject AgentOs.Modules.Tenants.ITenantSignupService SignupSvc

<PageTitle>Members — @Ctx.TenantId</PageTitle>

<div class="admin-page">
    <header class="admin-head">
        <div>
            <h1>Members of <code>@Ctx.TenantId</code></h1>
            <p class="admin-sub">@(_members?.Count ?? 0) member(s) · invitations are signed tokens (cannot be revoked before TTL)</p>
        </div>
    </header>

    @if (_loadError is not null)
    {
        <div class="login-error">@_loadError</div>
    }
    else if (_members is null)
    {
        <Spinner />
    }
    else
    {
        <table class="admin-tbl">
            <thead>
                <tr>
                    <th>Username</th>
                    <th>Email</th>
                    <th>Roles</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var m in _members)
                {
                    <tr>
                        <td>@m.Username</td>
                        <td>@(m.Email ?? "—")</td>
                        <td>@string.Join(", ", m.Roles)</td>
                        <td>
                            @if (!m.Enabled) { <Badge>disabled</Badge> }
                            else if (!m.EmailVerified) { <Badge>unverified</Badge> }
                            else { <Badge>active</Badge> }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }

    <section class="admin-section">
        <h2>Invite a member</h2>
        <div class="admin-invite">
            <Field Label="Email (optional)">
                <input type="email" @bind="_inviteEmail" placeholder="bob@@acme.test" autocomplete="email" />
            </Field>
            <Field Label="Role">
                <select @bind="_inviteRole">
                    <option value="member">Member</option>
                    <option value="admin">Admin</option>
                </select>
            </Field>
            <Field Label="TTL (hours)">
                <input type="number" min="1" max="168" @bind="_inviteTtl" />
            </Field>
            <Btn Variant="Btn.ButtonVariant.Primary" OnClick="MintInvite" Disabled="_busy">
                @(_busy ? "Generating…" : "Mint invite URL")
            </Btn>
        </div>

        @if (_inviteUrl is not null)
        {
            <div class="admin-invite-result">
                <div class="admin-invite-hint">Copy + send to your invitee. Expires @_inviteExpiresAt.ToString("u").</div>
                <textarea readonly rows="2" class="admin-invite-url">@_inviteUrl</textarea>
            </div>
        }
        @if (_inviteError is not null)
        {
            <div class="login-error">@_inviteError</div>
        }
    </section>
</div>

@code {
    private IReadOnlyList<KeycloakUser>? _members;
    private string? _loadError;
    private string _inviteEmail = "";
    private string _inviteRole = "member";
    private int _inviteTtl = 24;
    private bool _busy;
    private string? _inviteUrl;
    private DateTimeOffset _inviteExpiresAt;
    private string? _inviteError;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _members = await Kc.ListUsersByTenantAsync(Ctx.TenantId);
        }
        catch (InvalidOperationException ex)
        {
            _loadError = ex.Message;
        }
    }

    private void MintInvite()
    {
        if (_busy) { return; }
        _busy = true;
        _inviteError = null;
        try
        {
            var ttl = TimeSpan.FromHours(Math.Clamp(_inviteTtl, 1, 168));
            var token = SignupSvc.CreateInvitation(
                Ctx.TenantId,
                _inviteRole,
                string.IsNullOrWhiteSpace(_inviteEmail) ? null : _inviteEmail,
                ttl);
            _inviteExpiresAt = token.ExpiresAtUtc;
            _inviteUrl = $"/signup?invite={Uri.EscapeDataString(token.Token)}";
        }
        catch (ArgumentException ex) { _inviteError = ex.Message; }
        finally { _busy = false; }
    }
}
