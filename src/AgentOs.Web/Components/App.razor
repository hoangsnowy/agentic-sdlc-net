<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <title>AgentOS</title>
    <link rel="preconnect" href="https://rsms.me/" />
    <link rel="stylesheet" href="https://rsms.me/inter/inter.css" />
    <link rel="stylesheet" href="_content/Z.Blazor.Diagrams/style.min.css" />
    <link rel="stylesheet" href="app.css" />
    <link rel="stylesheet" href="orchestration.css" />
    <link rel="icon" href="data:," />
    <HeadOutlet @rendermode="@(new Microsoft.AspNetCore.Components.Web.InteractiveServerRenderMode(prerender: false))" />
</head>

<body>
    <Routes @rendermode="@(new Microsoft.AspNetCore.Components.Web.InteractiveServerRenderMode(prerender: false))" />

    @* Themed Blazor reconnection modal — overrides the framework's default white box. Blazor toggles the
       components-reconnect-{show,failed,rejected} classes on this element. *@
    <div id="components-reconnect-modal" class="reconnect-modal">
        <div class="reconnect-card">
            <div class="reconnect-spinner reconnect-when-show"></div>
            <div class="reconnect-title reconnect-when-show">Reconnecting…</div>
            <div class="reconnect-sub reconnect-when-show">Restoring your session.</div>

            <div class="reconnect-icon reconnect-when-failed">⚠</div>
            <div class="reconnect-title reconnect-when-failed">Connection lost</div>
            <div class="reconnect-sub reconnect-when-failed">The server is unreachable right now.</div>

            <div class="reconnect-icon reconnect-when-rejected">↻</div>
            <div class="reconnect-title reconnect-when-rejected">Session ended</div>
            <div class="reconnect-sub reconnect-when-rejected">Reload the page to continue.</div>

            <div class="reconnect-actions">
                <button class="reconnect-btn reconnect-when-failed" onclick="window.Blazor.reconnect()">Retry now</button>
                <button class="reconnect-btn reconnect-when-rejected" onclick="location.reload()">Reload</button>
            </div>
        </div>
    </div>

    <script src="_content/Z.Blazor.Diagrams/script.min.js"></script>
    <script src="theme.js"></script>
    <script src="_framework/blazor.web.js"></script>
</body>

</html>
