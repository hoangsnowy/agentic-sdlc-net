@inherits LayoutComponentBase
@inject Microsoft.JSInterop.IJSRuntime JS
@inject NavigationManager Nav
@inject AgentOs.Web.Services.WindowManagerService WM
@inject AgentOs.Web.Services.ToastService Toasts
@inject AgentOs.Web.Services.AuthSession Auth

<TopBar />

<div class="shell shell-deskmode">
    <div class="shell-pane">
        <main class="shell-main">
            @Body
        </main>

        @* All open desktop-app windows render here on top of the desktop. *@
        <WindowHost />

        <Taskbar StartOpen="_startOpen" OnToggleStart="ToggleStart" />
    </div>
</div>

@* ===== Start menu — Kickoff-style launcher: search · pinned grid · recents · user bar ===== *@
@if (_startOpen)
{
    <div class="start-menu-backdrop" @onclick="CloseStart" @oncontextmenu="CloseStart" @oncontextmenu:preventDefault="true"></div>
    <div class="kickoff" @onclick:stopPropagation="true" role="menu" aria-label="Start menu">

        <div class="ko-search">
            <span class="ko-search-ic"><Icon Name="search" Size="15" /></span>
            <input class="ko-search-input" type="text" placeholder="Search apps…"
                   autocomplete="off" spellcheck="false"
                   value="@_query" @oninput="OnSearch" @onkeydown="OnSearchKey" @ref="_searchRef" />
            @if (!string.IsNullOrEmpty(_query))
            {
                <button class="ko-search-clear" @onclick="ClearSearch" title="Clear" aria-label="Clear search">
                    <Icon Name="x" Size="13" />
                </button>
            }
        </div>

        <div class="ko-body">
            @if (string.IsNullOrWhiteSpace(_query))
            {
                <div class="ko-section-row">
                    <span class="ko-section">Pinned</span>
                </div>
                <div class="ko-grid">
                    @foreach (var app in AppCatalog.Pinned)
                    {
                        <button class="ko-tile" @onclick="@(() => Launch(app))" title="@app.Caption">
                            <span class="ko-tile-ic"><Icon Name="@app.Icon" Size="22" /></span>
                            <span class="ko-tile-label">@app.Title</span>
                        </button>
                    }
                </div>

                @if (_recents.Count > 0)
                {
                    <div class="ko-section-row">
                        <span class="ko-section">Recent</span>
                    </div>
                    <div class="ko-list">
                        @foreach (var app in _recents)
                        {
                            <button class="ko-row" @onclick="@(() => Launch(app))">
                                <span class="ko-row-ic"><Icon Name="@app.Icon" Size="16" /></span>
                                <span class="ko-row-text">
                                    <span class="ko-row-title">@app.Title</span>
                                    <span class="ko-row-cap">@app.Caption</span>
                                </span>
                            </button>
                        }
                    </div>
                }
            }
            else
            {
                <div class="ko-section-row">
                    <span class="ko-section">Results</span>
                    <span class="ko-section-count">@_results.Count</span>
                </div>
                @if (_results.Count == 0)
                {
                    <div class="ko-empty">
                        <Icon Name="search" Size="22" />
                        <span>No apps match “@_query”.</span>
                    </div>
                }
                else
                {
                    <div class="ko-list">
                        @foreach (var app in _results)
                        {
                            <button class="ko-row" @onclick="@(() => Launch(app))">
                                <span class="ko-row-ic"><Icon Name="@app.Icon" Size="16" /></span>
                                <span class="ko-row-text">
                                    <span class="ko-row-title">@app.Title</span>
                                    <span class="ko-row-cap">@app.Caption</span>
                                </span>
                                <span class="ko-row-cat">@app.Category</span>
                            </button>
                        }
                    </div>
                }
            }
        </div>

        <div class="ko-footer">
            <button class="ko-user" @onclick="ShowAbout" title="About AgentOS">
                <span class="ko-avatar">@AvatarLetter</span>
                <span class="ko-user-text">
                    <span class="ko-user-name">@(_user ?? "operator")</span>
                    <span class="ko-user-sub">AgentOS v1.0</span>
                </span>
            </button>
            <div class="ko-footer-actions">
                <a class="ko-fbtn" href="https://github.com/hoangsnowy/AgentOs" target="_blank"
                   @onclick="CloseStart" title="GitHub repository" aria-label="GitHub repository">
                    <Icon Name="arrow-square-out" Size="16" />
                </a>
                <button class="ko-fbtn" @onclick="ShowAbout" title="About" aria-label="About AgentOS">
                    <Icon Name="info" Size="16" />
                </button>
                <button class="ko-fbtn ko-fbtn-danger" @onclick="Lock" title="Lock screen" aria-label="Lock screen">
                    <Icon Name="power" Size="16" />
                </button>
            </div>
        </div>
    </div>
}

@* ===== About dialog ===== *@
<Dialog Show="_aboutOpen" Title="About — AgentOS" Width="440" OnClose="@(() => _aboutOpen = false)">
    <ChildContent>
        <h3 class="about-h">AgentOS</h3>
        <p class="about-tag">A .NET multi-agent AI framework for the software development lifecycle.</p>
        <table class="about-tbl">
            <tr><th>Version</th><td>1.0</td></tr>
            <tr><th>Runtime</th><td>.NET 10</td></tr>
            <tr><th>License</th><td>MIT</td></tr>
            <tr><th>Source</th><td><a href="https://github.com/hoangsnowy/AgentOs" target="_blank">github.com/hoangsnowy/AgentOs</a></td></tr>
        </table>
    </ChildContent>
    <Footer>
        <Btn OnClick="@(() => _aboutOpen = false)">Close</Btn>
    </Footer>
</Dialog>

<ToastHost />

@code {
    private bool _startOpen;
    private bool _aboutOpen;
    private string _query = "";
    private string? _user;
    private ElementReference _searchRef;
    private bool _focusOnRender;

    private string AvatarLetter => string.IsNullOrEmpty(_user) ? "O" : _user[..1].ToUpperInvariant();

    private List<DesktopApp> _recents = new();
    private List<DesktopApp> _results = new();

    private Task ToggleStart()
    {
        _startOpen = !_startOpen;
        if (_startOpen)
        {
            _query = "";
            RefreshRecents();
            _focusOnRender = true;
            _user ??= Auth.Username;
        }
        return Task.CompletedTask;
    }

    private void CloseStart() => _startOpen = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await RestorePreferencesAsync();
        }

        if (_focusOnRender)
        {
            _focusOnRender = false;
            try { await _searchRef.FocusAsync(); } catch { /* element gone */ }
        }
    }

    // Hydrate the persisted desktop preferences into the singleton services so they apply
    // app-wide (toast suppression, focus mode, auto-minimize) — not only while System is open.
    private async Task RestorePreferencesAsync()
    {
        try
        {
            var showToasts = await JS.InvokeAsync<string?>("localStorage.getItem", "pref-show-toasts");
            var focus = await JS.InvokeAsync<string?>("localStorage.getItem", "pref-focus");
            var autoMin = await JS.InvokeAsync<string?>("localStorage.getItem", "pref-auto-min");
            Toasts.ShowToasts = showToasts != "0";          // default on
            Toasts.FocusMode = focus == "1";                // default off
            WM.AutoMinimizeOnBlur = autoMin == "1";         // default off
        }
        catch { /* prerender / JS unavailable */ }
    }

    private void RefreshRecents()
    {
        _recents = WM.RecentKeys
            .Select(AppCatalog.Find)
            .Where(a => a is not null)
            .Cast<DesktopApp>()
            .ToList();
    }

    private void OnSearch(ChangeEventArgs e)
    {
        _query = e.Value?.ToString() ?? "";
        var q = _query.Trim();
        _results = string.IsNullOrEmpty(q)
            ? new()
            : AppCatalog.All
                .Where(a => a.Title.Contains(q, StringComparison.OrdinalIgnoreCase)
                         || a.Caption.Contains(q, StringComparison.OrdinalIgnoreCase)
                         || a.Category.Contains(q, StringComparison.OrdinalIgnoreCase))
                .ToList();
    }

    private void OnSearchKey(KeyboardEventArgs e)
    {
        if (e.Key == "Escape") { CloseStart(); }
        else if (e.Key == "Enter")
        {
            var first = !string.IsNullOrWhiteSpace(_query) ? _results.FirstOrDefault() : AppCatalog.Pinned.FirstOrDefault();
            if (first is not null) { Launch(first); }
        }
    }

    private void ClearSearch()
    {
        _query = "";
        _results = new();
        _focusOnRender = true;
    }

    private void Launch(DesktopApp app)
    {
        WM.OpenApp(app.Key, app.Title, app.Icon, app.W, app.H);
        _startOpen = false;
    }

    private void ShowAbout()
    {
        _aboutOpen = true;
        _startOpen = false;
    }

    private void Lock()
    {
        _startOpen = false;
        Nav.NavigateTo("/account/logout", forceLoad: true);
    }
}
