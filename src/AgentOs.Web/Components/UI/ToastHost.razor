@* ToastHost — renders the active toast queue, bottom-right slide-in. Subscribes to ToastService. *@

@implements IDisposable
@inject AgentOs.Web.Services.ToastService Toasts

@if (Toasts.Items.Count > 0)
{
    <div class="toast-container">
        @foreach (var t in Toasts.Items)
        {
            <div class="toast toast-@(t.Kind.ToString().ToLowerInvariant())" @key="t.Id">
                <span class="toast-ic">@KindIcon(t.Kind)</span>
                <div class="toast-body">
                    <div class="toast-title">@t.Title</div>
                    @if (!string.IsNullOrEmpty(t.Message))
                    {
                        <div class="toast-msg">@t.Message</div>
                    }
                </div>
                <button class="toast-close" @onclick="@(() => Toasts.Dismiss(t.Id))">×</button>
            </div>
        }
    </div>
}

@code {
    protected override void OnInitialized()
    {
        Toasts.Changed += OnChanged;
    }

    private void OnChanged() => InvokeAsync(StateHasChanged);

    private static string KindIcon(AgentOs.Web.Services.ToastKind k) => k switch
    {
        AgentOs.Web.Services.ToastKind.Ok => "✓",
        AgentOs.Web.Services.ToastKind.Warn => "⚠",
        AgentOs.Web.Services.ToastKind.Err => "✕",
        _ => "ℹ",
    };

    public void Dispose() => Toasts.Changed -= OnChanged;
}
