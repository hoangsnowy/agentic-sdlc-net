@* TopBar — GNOME / KDE Plasma top panel with dropdown menus. *@

@using AgentOs.Web.Services
@inject WindowManagerService WM
@inject ToastService Toasts
@inject IJSRuntime JS
@inject NavigationManager Nav
@inject AgentOs.Web.Services.AuthSession Auth
@inject Microsoft.Extensions.Configuration.IConfiguration Config
@inject IHttpClientFactory HttpFactory
@implements IDisposable

<div class="topbar">
    <div class="tb-left">
        <span class="tb-logo"><Icon Name="diamond" Size="12" /></span>
        <span class="tb-brand">AgentOS</span>
        <span class="tb-sep"></span>
        <span class="tb-workspace">Workspace 1</span>
    </div>

    <div class="tb-center">@ActiveTitle</div>

    <div class="tb-right">
        <span class="tb-indicator" title="@_healthTitle">
            <span class="tb-dot @(_online ? "ok" : "err")"></span> @(_online ? "Live" : "Offline")
        </span>
        <span class="tb-sep"></span>

        <button class="tb-trigger tb-icon-btn" @onclick="ToggleTheme"
                title="@(_theme == "dark" ? "Switch to light theme" : "Switch to dark theme")"
                aria-label="Toggle color theme">
            <Icon Name="@(_theme == "dark" ? "sun" : "moon")" Size="15" />
        </button>

        <span class="tb-sep"></span>

        <button class="tb-trigger tb-clock @(_clockOpen ? "open" : "")" title="@_today"
                @onclick="ToggleClock" @onclick:stopPropagation="true">
            @_now
        </button>

        <span class="tb-sep"></span>

        <button class="tb-trigger tb-user @(_userOpen ? "open" : "")" title="@(_user ?? "guest")"
                @onclick="ToggleUser" @onclick:stopPropagation="true">
            <span class="tb-avatar">@AvatarLetter</span>
            <span class="tb-name">@(_user ?? "guest")</span>
            <span class="tb-caret">▾</span>
        </button>
    </div>
</div>

<Dropdown Show="_clockOpen" ExtraClass="dropdown-clock" OnClose="@(() => _clockOpen = false)">
    <div class="dd-clock-big">@_now</div>
    <div class="dd-clock-date">@DateTime.Now.ToString("dddd")</div>
    <div class="dd-clock-sub">@DateTime.Now.ToString("d MMMM yyyy")</div>
    <div class="dd-sep"></div>
    <button class="dd-item" @onclick="OpenDateTimeSettings"><span class="dd-ic"><Icon Name="clock" Size="14" /></span> Date &amp; time settings</button>
</Dropdown>

<Dropdown Show="_userOpen" ExtraClass="dropdown-user" OnClose="@(() => _userOpen = false)">
    <div class="dd-user-head">
        <span class="dd-user-avatar">@AvatarLetter</span>
        <div>
            <div class="dd-user-name">@(_user ?? "guest")</div>
            <div class="dd-user-role">Local account</div>
        </div>
    </div>
    <div class="dd-sep"></div>
    <button class="dd-item" @onclick="OpenSystem"><span class="dd-ic"><Icon Name="wrench" Size="14" /></span> System settings</button>
    <button class="dd-item" @onclick="OpenSettings"><span class="dd-ic"><Icon Name="gear" Size="14" /></span> App settings</button>
    <div class="dd-sep"></div>
    <button class="dd-item" @onclick="Lock"><span class="dd-ic"><Icon Name="lock" Size="14" /></span> Lock screen</button>
    <button class="dd-item dd-danger" @onclick="SignOut"><span class="dd-ic"><Icon Name="power" Size="14" /></span> Sign out</button>
</Dropdown>

@code {
    private string _now = "";
    private string _today = "";
    private string? _user;
    private string AvatarLetter => string.IsNullOrEmpty(_user) ? "?" : _user[..1].ToUpperInvariant();

    private bool _userOpen;
    private bool _clockOpen;
    private string _theme = "light";

    private bool _online = true;
    private string _healthTitle = "LLM gateway online";
    private string? _apiBase;
    private int _tick;

    // Clock format prefs (System → Date & time). Defaults: 24h on, seconds on.
    private bool _clock24 = true;
    private bool _clockSeconds = true;

    private System.Threading.Timer? _timer;

    private string ActiveTitle
    {
        get
        {
            var w = WM.Open
                .Where(x => !x.Minimized)
                .OrderByDescending(x => x.Z)
                .FirstOrDefault();
            return w is null ? "AgentOS — Desktop" : w.Title;
        }
    }

    protected override void OnInitialized()
    {
        UpdateClock();
        _apiBase = Config["Api:BaseUrl"];
        _timer = new System.Threading.Timer(_ => InvokeAsync(OnTick),
            null, TimeSpan.FromSeconds(1), TimeSpan.FromSeconds(1));
        WM.Changed += OnChanged;
        WM.ClockPrefsChanged += OnClockPrefsChanged;
        _ = CheckHealthAsync();
    }

    // System → Date & time toggled a format pref → re-read + repaint the clock.
    private void OnClockPrefsChanged() => InvokeAsync(async () =>
    {
        await LoadClockPrefsAsync();
        UpdateClock();
        StateHasChanged();
    });

    private async Task LoadClockPrefsAsync()
    {
        try
        {
            _clock24 = (await JS.InvokeAsync<string?>("localStorage.getItem", "pref-clock-24h")) != "0";
            _clockSeconds = (await JS.InvokeAsync<string?>("localStorage.getItem", "pref-clock-seconds")) != "0";
        }
        catch { /* prerender / JS unavailable — keep defaults */ }
    }

    private async Task OnTick()
    {
        UpdateClock();
        // Re-check gateway health every 15s (not every tick).
        if (++_tick % 15 == 0) { await CheckHealthAsync(); }
        StateHasChanged();
    }

    // In-process mode (no Api:BaseUrl) the gateway runs locally → always up. In split mode,
    // probe the API's public /health endpoint.
    private async Task CheckHealthAsync()
    {
        if (string.IsNullOrWhiteSpace(_apiBase))
        {
            _online = true;
            _healthTitle = "LLM gateway online (in-process)";
            return;
        }
        try
        {
            using var client = HttpFactory.CreateClient();
            client.BaseAddress = new Uri(_apiBase.EndsWith('/') ? _apiBase : _apiBase + "/");
            client.Timeout = TimeSpan.FromSeconds(3);
            using var resp = await client.GetAsync("health");
            _online = resp.IsSuccessStatusCode;
            _healthTitle = _online ? $"API healthy — {_apiBase}" : $"API returned {(int)resp.StatusCode} — {_apiBase}";
        }
        catch (Exception ex)
        {
            _online = false;
            _healthTitle = $"API unreachable — {ex.Message}";
        }
    }

    private void OnChanged() => InvokeAsync(StateHasChanged);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _user = Auth.Username;
            await LoadClockPrefsAsync();
            UpdateClock();
            try
            {
                _theme = await JS.InvokeAsync<string>("agenticTheme.getTheme");
            }
            catch { }
            StateHasChanged();
        }
    }

    private async Task ToggleTheme()
    {
        try
        {
            _theme = await JS.InvokeAsync<string>("agenticTheme.toggleAppearance");
        }
        catch { /* JS unavailable (prerender) */ }
    }

    private void UpdateClock()
    {
        var now = DateTime.Now;
        var timeFmt = (_clock24, _clockSeconds) switch
        {
            (true, true) => "HH:mm:ss",
            (true, false) => "HH:mm",
            (false, true) => "h:mm:ss tt",
            (false, false) => "h:mm tt",
        };
        _now = now.ToString(timeFmt);
        _today = now.ToString("dddd, d MMMM yyyy");
    }

    private void ToggleUser()  { _userOpen = !_userOpen; _clockOpen = false; }
    private void ToggleClock() { _clockOpen = !_clockOpen; _userOpen = false; }

    private void OpenSystem()
    {
        WM.OpenApp("system", "System", "wrench", 760, 600);
        _userOpen = _clockOpen = false;
    }

    private void OpenDateTimeSettings()
    {
        // Deep-link the System app straight to its Date & time tab.
        WM.RequestLaunchTab("system", "datetime");
        WM.OpenApp("system", "System", "wrench", 760, 600);
        _clockOpen = false;
    }

    private void OpenSettings()
    {
        WM.OpenApp("settings", "Settings", "gear", 760, 600);
        _userOpen = false;
    }

    private void Lock() => Nav.NavigateTo("/account/logout", forceLoad: true);

    private void SignOut()
    {
        _userOpen = false;
        Nav.NavigateTo("/account/logout", forceLoad: true);
    }

    public void Dispose()
    {
        _timer?.Dispose();
        WM.Changed -= OnChanged;
        WM.ClockPrefsChanged -= OnClockPrefsChanged;
    }
}
