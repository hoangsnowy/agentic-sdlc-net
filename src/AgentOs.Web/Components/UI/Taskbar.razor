@* Floating dock (bottom-center) + system tray (top-right) — macOS / KDE Latte vibe. *@

@using AgentOs.Web.Services
@using Microsoft.AspNetCore.Components.Authorization
@inject WindowManagerService WM
@inject IJSRuntime JS
@implements IDisposable

@* ===== Dock (floating bottom-center pill) ===== *@
<div class="dock" role="toolbar" aria-label="Application dock">
    <button class="dock-item dock-start @(StartOpen ? "open" : "")"
            @onclick="ToggleStart" @onclick:stopPropagation="true"
            title="Start menu" aria-label="Start menu">
        <span class="di-ic"><Icon Name="squares-four" Size="18" /></span>
    </button>

    <span class="dock-sep"></span>

    @foreach (var app in AppCatalog.VisiblePinned(_isAdmin))
    {
        var isOpen = WM.Open.Any(o => o.AppKey == app.Key);
        <button class="dock-item @(isOpen ? "running" : "")"
                @onclick="@(() => Launch(app))"
                title="@app.Title" aria-label="@app.Title">
            <span class="di-ic"><Icon Name="@app.Icon" Size="18" /></span>
            @if (isOpen)
            {
                <span class="di-dot"></span>
            }
        </button>
    }

    @{
        var floating = WM.Open.Where(w => !AppCatalog.Pinned.Any(p => p.Key == w.AppKey)).ToList();
    }
    @if (floating.Count > 0)
    {
        <span class="dock-sep"></span>
        @foreach (var w in floating)
        {
            <button class="dock-item running @(w.Minimized ? "min" : "")"
                    @onclick="@(() => OnTaskClick(w))"
                    title="@w.Title" aria-label="@w.Title">
                <span class="di-ic"><Icon Name="@w.Icon" Size="18" /></span>
                <span class="di-dot"></span>
            </button>
        }
    }
</div>

@code {
    [Parameter] public bool StartOpen { get; set; }
    [Parameter] public EventCallback OnToggleStart { get; set; }
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private string _now = "";
    private string _today = "";
    private string? _user;
    private bool _isAdmin;
    private string AvatarLetter => string.IsNullOrEmpty(_user) ? "?" : _user[..1].ToUpperInvariant();

    private System.Threading.Timer? _timer;

    protected override void OnInitialized()
    {
        UpdateClock();
        _timer = new System.Threading.Timer(_ => InvokeAsync(() => { UpdateClock(); StateHasChanged(); }),
            null, TimeSpan.FromSeconds(1), TimeSpan.FromSeconds(1));
        WM.Changed += OnWmChanged;
    }

    protected override async Task OnInitializedAsync()
    {
        if (AuthState is not null)
        {
            var state = await AuthState;
            _isAdmin = state.User.IsInRole("admin");
        }
    }

    private void OnWmChanged() => InvokeAsync(StateHasChanged);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                _user = await JS.InvokeAsync<string?>("localStorage.getItem", "agentic-signed-in");
                StateHasChanged();
            }
            catch { }
        }
    }

    private void UpdateClock()
    {
        var now = DateTime.Now;
        _now = now.ToString("HH:mm:ss");
        _today = now.ToString("dddd, d MMMM yyyy");
    }

    private void OnTaskClick(AppWindowState w)
    {
        if (w.Minimized) { WM.Restore(w.Id); }
        else { WM.Focus(w.Id); }
    }

    private void Launch(DesktopApp app)
    {
        WM.OpenApp(app.Key, app.Title, app.Icon, app.W, app.H);
    }

    private Task ToggleStart() => OnToggleStart.InvokeAsync();


    public void Dispose()
    {
        _timer?.Dispose();
        WM.Changed -= OnWmChanged;
    }
}
