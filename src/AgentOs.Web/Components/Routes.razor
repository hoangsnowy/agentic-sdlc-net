@using Microsoft.AspNetCore.Components.Authorization

<Router AppAssembly="@typeof(Program).Assembly">
    <Found Context="routeData">
        <AuthorizeRouteView RouteData="@routeData" DefaultLayout="@typeof(AppShellLayout)">
            <NotAuthorized>
                @{
                    NavigationManager.NavigateTo($"/login?returnUrl={Uri.EscapeDataString(NavigationManager.Uri)}", forceLoad: true);
                }
            </NotAuthorized>
        </AuthorizeRouteView>
        <FocusOnNavigate RouteData="@routeData" Selector="h1" />
    </Found>
    <NotFound>
        <LayoutView Layout="@typeof(AppShellLayout)">
            <p role="alert">Page not found.</p>
        </LayoutView>
    </NotFound>
</Router>

@code {
    [Inject] private NavigationManager NavigationManager { get; set; } = default!;
}
