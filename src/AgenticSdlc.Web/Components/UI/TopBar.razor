@* TopBar — GNOME / KDE Plasma top panel with dropdown menus. *@

@using AgenticSdlc.Web.Services
@inject WindowManagerService WM
@inject ToastService Toasts
@inject IJSRuntime JS
@inject NavigationManager Nav
@implements IDisposable

<div class="topbar">
    <div class="tb-left">
        <span class="tb-logo"><Icon Name="diamond" Size="12" /></span>
        <span class="tb-brand">AgentOS</span>
        <span class="tb-sep"></span>
        <span class="tb-workspace">Workspace 1</span>
    </div>

    <div class="tb-center">@ActiveTitle</div>

    <div class="tb-right">
        <span class="tb-indicator" title="LLM gateway online">
            <span class="tb-dot ok"></span> Live
        </span>
        <span class="tb-sep"></span>

        <button class="tb-trigger tb-clock @(_clockOpen ? "open" : "")" title="@_today"
                @onclick="ToggleClock" @onclick:stopPropagation="true">
            @_now
        </button>

        <span class="tb-sep"></span>

        <button class="tb-trigger tb-user @(_userOpen ? "open" : "")" title="@(_user ?? "guest")"
                @onclick="ToggleUser" @onclick:stopPropagation="true">
            <span class="tb-avatar">@AvatarLetter</span>
            <span class="tb-name">@(_user ?? "guest")</span>
            <span class="tb-caret">▾</span>
        </button>
    </div>
</div>

<Dropdown Show="_clockOpen" ExtraClass="dropdown-clock" OnClose="@(() => _clockOpen = false)">
    <div class="dd-clock-big">@DateTime.Now.ToString("HH:mm:ss")</div>
    <div class="dd-clock-date">@DateTime.Now.ToString("dddd")</div>
    <div class="dd-clock-sub">@DateTime.Now.ToString("d MMMM yyyy")</div>
    <div class="dd-sep"></div>
    <button class="dd-item" @onclick="OpenSystem"><span class="dd-ic"><Icon Name="clock" Size="14" /></span> Date &amp; time settings</button>
</Dropdown>

<Dropdown Show="_userOpen" ExtraClass="dropdown-user" OnClose="@(() => _userOpen = false)">
    <div class="dd-user-head">
        <span class="dd-user-avatar">@AvatarLetter</span>
        <div>
            <div class="dd-user-name">@(_user ?? "guest")</div>
            <div class="dd-user-role">Local account</div>
        </div>
    </div>
    <div class="dd-sep"></div>
    <button class="dd-item" @onclick="OpenSystem"><span class="dd-ic"><Icon Name="wrench" Size="14" /></span> System settings</button>
    <button class="dd-item" @onclick="OpenSettings"><span class="dd-ic"><Icon Name="gear" Size="14" /></span> App settings</button>
    <div class="dd-sep"></div>
    <button class="dd-item" @onclick="Lock"><span class="dd-ic"><Icon Name="lock" Size="14" /></span> Lock screen</button>
    <button class="dd-item dd-danger" @onclick="SignOut"><span class="dd-ic"><Icon Name="power" Size="14" /></span> Sign out</button>
</Dropdown>

@code {
    private string _now = "";
    private string _today = "";
    private string? _user;
    private string AvatarLetter => string.IsNullOrEmpty(_user) ? "?" : _user[..1].ToUpperInvariant();

    private bool _userOpen;
    private bool _clockOpen;

    private System.Threading.Timer? _timer;

    private string ActiveTitle
    {
        get
        {
            var w = WM.Open
                .Where(x => !x.Minimized)
                .OrderByDescending(x => x.Z)
                .FirstOrDefault();
            return w is null ? "AgentOS — Desktop" : w.Title;
        }
    }

    protected override void OnInitialized()
    {
        UpdateClock();
        _timer = new System.Threading.Timer(_ => InvokeAsync(() => { UpdateClock(); StateHasChanged(); }),
            null, TimeSpan.FromSeconds(1), TimeSpan.FromSeconds(1));
        WM.Changed += OnChanged;
    }

    private void OnChanged() => InvokeAsync(StateHasChanged);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                _user = await JS.InvokeAsync<string?>("localStorage.getItem", "agentic-signed-in");
                StateHasChanged();
            }
            catch { }
        }
    }

    private void UpdateClock()
    {
        var now = DateTime.Now;
        _now = now.ToString("HH:mm:ss");
        _today = now.ToString("dddd, d MMMM yyyy");
    }

    private void ToggleUser()  { _userOpen = !_userOpen; _clockOpen = false; }
    private void ToggleClock() { _clockOpen = !_clockOpen; _userOpen = false; }

    private void OpenSystem()
    {
        WM.OpenApp("system", "System", "wrench", 760, 600);
        _userOpen = _clockOpen = false;
    }

    private void OpenSettings()
    {
        WM.OpenApp("settings", "Settings", "gear", 760, 600);
        _userOpen = false;
    }

    private async Task Lock()
    {
        await JS.InvokeVoidAsync("localStorage.removeItem", "agentic-signed-in");
        Nav.NavigateTo(Nav.Uri, forceLoad: true);
    }

    private async Task SignOut()
    {
        await JS.InvokeVoidAsync("localStorage.removeItem", "agentic-signed-in");
        Toasts.Show("Signed out", "Refresh to sign in again.", ToastKind.Info);
        _userOpen = false;
    }

    public void Dispose()
    {
        _timer?.Dispose();
        WM.Changed -= OnChanged;
    }
}
