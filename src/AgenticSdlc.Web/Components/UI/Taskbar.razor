@* Taskbar — bottom dock with Start button, pinned apps, tray (clock + theme + user). *@

@inject NavigationManager Nav
@inject IJSRuntime JS
@implements IDisposable

<div class="taskbar">
    <button class="tb-start @(StartOpen ? "open" : "")" @onclick="ToggleStart" @onclick:stopPropagation="true" title="Open Start menu">
        <span class="tb-start-glyph">⊞</span> Start
    </button>

    <div class="tb-divider"></div>

    <div class="tb-pinned">
        <a class="tb-app @(IsActive("/") ? "active" : "")" href="/" title="Desktop">🖥</a>
        <a class="tb-app @(IsActive("/pipeline") ? "active" : "")" href="/pipeline" title="Pipeline">▶</a>
        <a class="tb-app @(IsActive("/orchestration") ? "active" : "")" href="/orchestration" title="Workflow">🕸</a>
        <a class="tb-app @(IsActive("/settings") ? "active" : "")" href="/settings" title="Settings">⚙</a>
    </div>

    <div class="tb-spacer"></div>

    <div class="tb-tray">
        <button class="tb-tray-item" @onclick="ToggleTheme" title="Toggle theme">@_themeIcon</button>
        <span class="tb-tray-item tb-clock" title="@_today">@_now</span>
        <div class="tb-tray-item tb-user" title="@(_user ?? "guest")">
            <span class="tb-avatar">@AvatarLetter</span>
            <span>@(_user ?? "guest")</span>
        </div>
    </div>
</div>

@code {
    [Parameter] public bool StartOpen { get; set; }
    [Parameter] public EventCallback OnToggleStart { get; set; }
    [Parameter] public EventCallback OnToggleTheme { get; set; }
    [Parameter] public string Theme { get; set; } = "light";

    private string _now = "";
    private string _today = "";
    private string? _user;
    private string _themeIcon => Theme == "light" ? "🌙" : "☀";
    private string AvatarLetter => string.IsNullOrEmpty(_user) ? "?" : _user[..1].ToUpperInvariant();

    private System.Threading.Timer? _timer;

    protected override void OnInitialized()
    {
        UpdateClock();
        _timer = new System.Threading.Timer(_ => InvokeAsync(() => { UpdateClock(); StateHasChanged(); }),
            null, TimeSpan.FromSeconds(1), TimeSpan.FromSeconds(1));
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                _user = await JS.InvokeAsync<string?>("localStorage.getItem", "agentic-signed-in");
                StateHasChanged();
            }
            catch { /* JS interop may not be ready */ }
        }
    }

    private void UpdateClock()
    {
        var now = DateTime.Now;
        _now = now.ToString("HH:mm");
        _today = now.ToString("dddd, d MMMM yyyy");
    }

    private bool IsActive(string path)
    {
        var current = new Uri(Nav.Uri).AbsolutePath;
        if (path == "/") return current == "/";
        return current.StartsWith(path, StringComparison.OrdinalIgnoreCase);
    }

    private Task ToggleStart() => OnToggleStart.InvokeAsync();
    private Task ToggleTheme() => OnToggleTheme.InvokeAsync();

    public void Dispose() => _timer?.Dispose();
}
