@* Floating dock (bottom-center) + system tray (top-right) — macOS / KDE Latte vibe. *@

@using AgenticSdlc.Web.Services
@inject WindowManagerService WM
@inject IJSRuntime JS
@implements IDisposable

@* ===== Dock (floating bottom-center pill) ===== *@
<div class="dock">
    <button class="dock-item dock-start @(StartOpen ? "open" : "")" @onclick="ToggleStart" @onclick:stopPropagation="true" title="Start menu">
        <span class="di-ic">⊞</span>
    </button>

    <span class="dock-sep"></span>

    @foreach (var app in _pinned)
    {
        var isOpen = WM.Open.Any(o => o.AppKey == app.Key);
        <button class="dock-item @(isOpen ? "running" : "")"
                @onclick="@(() => Launch(app))"
                title="@app.Title">
            <span class="di-ic">@app.Icon</span>
            @if (isOpen)
            {
                <span class="di-dot"></span>
            }
        </button>
    }

    @{
        var floating = WM.Open.Where(w => !_pinned.Any(p => p.Key == w.AppKey)).ToList();
    }
    @if (floating.Count > 0)
    {
        <span class="dock-sep"></span>
        @foreach (var w in floating)
        {
            <button class="dock-item running @(w.Minimized ? "min" : "")"
                    @onclick="@(() => OnTaskClick(w))"
                    title="@w.Title">
                <span class="di-ic">@w.Icon</span>
                <span class="di-dot"></span>
            </button>
        }
    }
</div>

@code {
    [Parameter] public bool StartOpen { get; set; }
    [Parameter] public EventCallback OnToggleStart { get; set; }

    private string _now = "";
    private string _today = "";
    private string? _user;
    private string AvatarLetter => string.IsNullOrEmpty(_user) ? "?" : _user[..1].ToUpperInvariant();

    private System.Threading.Timer? _timer;

    private sealed record PinnedApp(string Key, string Title, string Icon, int Width, int Height);

    private readonly List<PinnedApp> _pinned = new()
    {
        new("pipeline", "Pipeline", "▶", 920, 620),
        new("workflow", "Workflow", "🕸", 1080, 660),
        new("settings", "Settings", "⚙", 720, 600),
        new("system",   "System",   "🛠", 540, 520),
    };

    protected override void OnInitialized()
    {
        UpdateClock();
        _timer = new System.Threading.Timer(_ => InvokeAsync(() => { UpdateClock(); StateHasChanged(); }),
            null, TimeSpan.FromSeconds(1), TimeSpan.FromSeconds(1));
        WM.Changed += OnWmChanged;
    }

    private void OnWmChanged() => InvokeAsync(StateHasChanged);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                _user = await JS.InvokeAsync<string?>("localStorage.getItem", "agentic-signed-in");
                StateHasChanged();
            }
            catch { }
        }
    }

    private void UpdateClock()
    {
        var now = DateTime.Now;
        _now = now.ToString("HH:mm:ss");
        _today = now.ToString("dddd, d MMMM yyyy");
    }

    private void Launch(PinnedApp app)
    {
        WM.OpenApp(app.Key, app.Title, app.Icon, app.Width, app.Height);
    }

    private void OnTaskClick(AppWindowState w)
    {
        if (w.Minimized) { WM.Restore(w.Id); }
        else { WM.Focus(w.Id); }
    }

    private Task ToggleStart() => OnToggleStart.InvokeAsync();

    public void Dispose()
    {
        _timer?.Dispose();
        WM.Changed -= OnWmChanged;
    }
}
