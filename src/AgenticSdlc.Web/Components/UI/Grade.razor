@* Grade — letter chip A/B/C/D/F derived from a 0..1 score. *@

<span class="grade @Letter">@Letter</span>

@code {
    [Parameter] public double Score { get; set; }

    private string Letter => Score switch
    {
        >= 0.9 => "A",
        >= 0.8 => "B",
        >= 0.7 => "C",
        >= 0.6 => "D",
        _ => "F",
    };
}
