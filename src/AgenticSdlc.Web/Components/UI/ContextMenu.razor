@* ContextMenu — right-click menu. Consumer sets Show / X / Y and an ItemContent fragment. *@

@if (Show)
{
    <div class="ctxmenu-backdrop" @onclick="OnClose" @oncontextmenu="OnClose" @oncontextmenu:preventDefault="true"></div>
    <div class="ctxmenu" style="left:@(X)px; top:@(Y)px;" @onclick:stopPropagation="true">
        @ChildContent
    </div>
}

@code {
    [Parameter] public bool Show { get; set; }
    [Parameter] public int X { get; set; }
    [Parameter] public int Y { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
}
