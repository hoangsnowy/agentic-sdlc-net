@* Login splash overlay — full-screen on first visit. Posts credentials to the API /auth/token
   and stores the JWT in AuthSession (per-circuit) + localStorage (across refresh).
   When Api:BaseUrl is unset (in-process dev mode) any non-empty username is accepted offline. *@

@inject IJSRuntime JS
@inject AgenticSdlc.Web.Services.AuthSession Auth
@inject Microsoft.Extensions.Configuration.IConfiguration Config
@inject IHttpClientFactory HttpFactory
@inject ILogger<LoginOverlay> Log

@if (_show)
{
    <div class="login-overlay">
        <div class="login-card">
            <div class="login-brand">
                <div class="brand-mark"><Icon Name="diamond" Size="14" /></div>
                <div>
                    <div class="brand-title">AgentOS</div>
                    <div class="brand-sub">.NET multi-agent framework</div>
                </div>
            </div>

            <div class="login-form">
                <Field Label="Username">
                    <input type="text" @bind="_user" placeholder="operator" autocomplete="username" />
                </Field>
                <Field Label="Password">
                    <input type="password" @bind="_pass" placeholder="••••••••" autocomplete="current-password" />
                </Field>
                <Btn Variant="Btn.ButtonVariant.Primary" ExtraClass="login-btn" OnClick="SignIn" Disabled="_busy">
                    @(_busy ? "Signing in…" : "Sign in")
                </Btn>
                @if (!string.IsNullOrEmpty(_error))
                {
                    <div class="login-error">@_error</div>
                }
                <div class="login-hint">
                    @if (_inProcess) { <text>In-process mode — any non-empty user is accepted.</text> }
                    else             { <text>Sends credentials to the API at @_apiBaseUrl.</text> }
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool _show;
    private bool _busy;
    private string _user = "operator";
    private string _pass = "operator";
    private string _error = "";
    private bool _inProcess;
    private string _apiBaseUrl = "";

    private const string TokenKey = "agentic-jwt";
    private const string UserKey = "agentic-user";
    private const string ExpKey = "agentic-jwt-exp";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) { return; }
        _apiBaseUrl = Config["Api:BaseUrl"] ?? "";
        _inProcess = string.IsNullOrWhiteSpace(_apiBaseUrl);

        // Rehydrate from localStorage if a valid JWT is still cached.
        try
        {
            var token = await JS.InvokeAsync<string?>("localStorage.getItem", TokenKey);
            var user = await JS.InvokeAsync<string?>("localStorage.getItem", UserKey);
            var expStr = await JS.InvokeAsync<string?>("localStorage.getItem", ExpKey);
            if (!string.IsNullOrWhiteSpace(token) && !string.IsNullOrWhiteSpace(user))
            {
                DateTime? exp = DateTime.TryParse(expStr, System.Globalization.CultureInfo.InvariantCulture, System.Globalization.DateTimeStyles.RoundtripKind, out var parsed) ? parsed : null;
                if (exp is null || exp > DateTime.UtcNow.AddMinutes(1))
                {
                    Auth.SetToken(token, user, exp);
                    _show = false;
                    StateHasChanged();
                    return;
                }
            }
        }
        catch (Exception ex)
        {
            Log.LogWarning(ex, "Failed to read JWT from localStorage");
        }

        _show = !Auth.IsAuthenticated;
        StateHasChanged();
    }

    private async Task SignIn()
    {
        if (_busy) { return; }
        _busy = true;
        _error = "";
        try
        {
            if (string.IsNullOrWhiteSpace(_user))
            {
                _error = "Username required.";
                return;
            }

            if (_inProcess)
            {
                // No API to call. Accept any non-empty username for offline / demo mode.
                Auth.SetToken("inprocess", _user, null);
                await PersistAsync("inprocess", _user, null);
                _show = false;
                return;
            }

            using var client = HttpFactory.CreateClient();
            client.BaseAddress = new Uri(_apiBaseUrl.EndsWith('/') ? _apiBaseUrl : _apiBaseUrl + "/");
            using var resp = await client.PostAsJsonAsync("auth/token", new { user = _user, password = _pass });
            if (!resp.IsSuccessStatusCode)
            {
                _error = resp.StatusCode == System.Net.HttpStatusCode.Unauthorized
                    ? "Invalid credentials."
                    : $"Login failed: {(int)resp.StatusCode} {resp.ReasonPhrase}";
                return;
            }
            var body = await resp.Content.ReadFromJsonAsync<TokenResponse>();
            if (body is null || string.IsNullOrWhiteSpace(body.Token))
            {
                _error = "Login response missing token.";
                return;
            }
            Auth.SetToken(body.Token, _user, body.ExpiresAtUtc);
            await PersistAsync(body.Token, _user, body.ExpiresAtUtc);
            _show = false;
        }
        catch (Exception ex)
        {
            Log.LogError(ex, "Login error");
            _error = ex.Message;
        }
        finally
        {
            _busy = false;
            StateHasChanged();
        }
    }

    private async Task PersistAsync(string token, string user, DateTime? exp)
    {
        await JS.InvokeVoidAsync("localStorage.setItem", TokenKey, token);
        await JS.InvokeVoidAsync("localStorage.setItem", UserKey, user);
        if (exp is not null)
        {
            await JS.InvokeVoidAsync("localStorage.setItem", ExpKey, exp.Value.ToString("o", System.Globalization.CultureInfo.InvariantCulture));
        }
        else
        {
            await JS.InvokeVoidAsync("localStorage.removeItem", ExpKey);
        }
        // Back-compat with the legacy flag a few components still check.
        await JS.InvokeVoidAsync("localStorage.setItem", "agentic-signed-in", user);
    }

    private sealed record TokenResponse(string Token, DateTime ExpiresAtUtc);
}
