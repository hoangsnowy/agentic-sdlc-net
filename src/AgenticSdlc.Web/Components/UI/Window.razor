@* Reusable desktop-style window: drag by titlebar, close button, z-order. *@

<div class="window @(_dragging ? "dragging" : "")"
     style="left:@(X)px; top:@(Y)px; width:@(W)px; height:@(H)px; z-index:@Z;">
    <div class="window-titlebar" @onmousedown="StartDrag" @onmousedown:stopPropagation="true">
        <span class="window-title">@Title</span>
        <button class="window-close" @onclick="OnClose">×</button>
    </div>
    <div class="window-body">
        @ChildContent
    </div>
</div>

@if (_dragging)
{
    <div class="drag-overlay" @onmousemove="OnDrag" @onmouseup="EndDrag" @onmouseleave="EndDrag"></div>
}

@code {
    [Parameter] public string Title { get; set; } = "Window";
    [Parameter] public int X { get; set; } = 120;
    [Parameter] public int Y { get; set; } = 100;
    [Parameter] public int W { get; set; } = 420;
    [Parameter] public int H { get; set; } = 280;
    [Parameter] public int Z { get; set; } = 100;
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }

    private bool _dragging;
    private double _startMouseX, _startMouseY;
    private int _startWinX, _startWinY;

    private void StartDrag(MouseEventArgs e)
    {
        _dragging = true;
        _startMouseX = e.ClientX;
        _startMouseY = e.ClientY;
        _startWinX = X;
        _startWinY = Y;
    }

    private void OnDrag(MouseEventArgs e)
    {
        if (!_dragging) return;
        X = _startWinX + (int)(e.ClientX - _startMouseX);
        Y = _startWinY + (int)(e.ClientY - _startMouseY);
        if (X < 0) X = 0;
        if (Y < 0) Y = 0;
    }

    private void EndDrag(MouseEventArgs e) => _dragging = false;
}
