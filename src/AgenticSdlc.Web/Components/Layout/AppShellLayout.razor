@inherits LayoutComponentBase
@inject Microsoft.JSInterop.IJSRuntime JS
@inject NavigationManager Nav
@inject AgenticSdlc.Web.Services.WindowManagerService WM
@inject AgenticSdlc.Web.Services.AuthSession Auth

<LoginOverlay />

<TopBar />

<div class="shell shell-deskmode">
    <div class="shell-pane">
        <main class="shell-main">
            @Body
        </main>

        @* All open desktop-app windows render here on top of the desktop. *@
        <WindowHost />

        <Taskbar StartOpen="_startOpen" OnToggleStart="ToggleStart" />
    </div>
</div>

@* ===== Start menu — flat launcher anchored above the dock ===== *@
@if (_startOpen)
{
    <div class="start-menu-backdrop" @onclick="CloseStart" @oncontextmenu="CloseStart" @oncontextmenu:preventDefault="true"></div>
    <div class="start-menu start-menu-dock" @onclick:stopPropagation="true" role="menu" aria-label="Start menu">
        <div class="sm-header">
            <div class="sm-brand-mark"><Icon Name="diamond" Size="14" /></div>
            <div>
                <div class="sm-brand-title">AgentOS</div>
                <div class="sm-brand-sub">v1.0 · open source</div>
            </div>
        </div>

        <div class="sm-section">Apps</div>
        <button class="sm-item" @onclick="@(() => OpenApp("pipeline", "Pipeline", "play"))">
            <span class="sm-ic"><Icon Name="play" Size="14" /></span> Pipeline
        </button>
        <button class="sm-item" @onclick="@(() => OpenApp("workflow", "Workflow", "graph", 1080, 660))">
            <span class="sm-ic"><Icon Name="graph" Size="14" /></span> Workflow
        </button>
        <button class="sm-item" @onclick="@(() => OpenApp("settings", "Settings", "gear", 720, 600))">
            <span class="sm-ic"><Icon Name="gear" Size="14" /></span> Settings
        </button>
        <button class="sm-item" @onclick="@(() => OpenApp("system", "System", "wrench", 760, 600))">
            <span class="sm-ic"><Icon Name="wrench" Size="14" /></span> System
        </button>

        <div class="sm-sep"></div>

        <div class="sm-section">Session</div>
        <button class="sm-item" @onclick="ShowAbout">
            <span class="sm-ic"><Icon Name="info" Size="14" /></span> About AgentOS
        </button>
        <a class="sm-item" href="https://github.com/hoangsnowy/agentic-sdlc-net" target="_blank" @onclick="CloseStart">
            <span class="sm-ic"><Icon Name="arrow-square-out" Size="14" /></span> GitHub repo
        </a>
        <button class="sm-item sm-danger" @onclick="Lock">
            <span class="sm-ic"><Icon Name="lock" Size="14" /></span> Lock screen
        </button>
    </div>
}

@* ===== About dialog ===== *@
<Dialog Show="_aboutOpen" Title="About — AgentOS" Width="440" OnClose="@(() => _aboutOpen = false)">
    <ChildContent>
        <h3 class="about-h">AgentOS</h3>
        <p class="about-tag">A .NET multi-agent AI framework for the software development lifecycle.</p>
        <table class="about-tbl">
            <tr><th>Version</th><td>1.0</td></tr>
            <tr><th>Runtime</th><td>.NET 10</td></tr>
            <tr><th>License</th><td>MIT</td></tr>
            <tr><th>Source</th><td><a href="https://github.com/hoangsnowy/agentic-sdlc-net" target="_blank">github.com/hoangsnowy/agentic-sdlc-net</a></td></tr>
        </table>
    </ChildContent>
    <Footer>
        <Btn OnClick="@(() => _aboutOpen = false)">Close</Btn>
    </Footer>
</Dialog>

<ToastHost />

@code {
    private bool _startOpen;
    private bool _aboutOpen;

    private void ToggleStart() => _startOpen = !_startOpen;
    private void CloseStart() => _startOpen = false;

    private void OpenApp(string key, string title, string icon, int w = 920, int h = 620)
    {
        WM.OpenApp(key, title, icon, w, h);
        _startOpen = false;
    }

    private void ShowAbout()
    {
        _aboutOpen = true;
        _startOpen = false;
    }

    private async Task Lock()
    {
        _startOpen = false;
        await JS.InvokeVoidAsync("agenticAuth.signOut");
        Auth.Clear();
        Nav.NavigateTo(Nav.Uri, forceLoad: true);
    }
}
