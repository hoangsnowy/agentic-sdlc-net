@inherits LayoutComponentBase
@inject Microsoft.JSInterop.IJSRuntime JS

<div class="shell">

    <aside class="shell-sidebar">
        <div class="shell-brand">
            <span class="brand-mark">◆</span>
            <div class="brand-text">
                <div class="brand-title">Agentic SDLC</div>
                <div class="brand-sub">Multi-agent framework</div>
            </div>
        </div>

        <nav class="shell-nav">
            <div class="nav-section">Workspace</div>
            <NavLink class="nav-item" Match="NavLinkMatch.All" href="/">
                <span class="nav-ic">▶</span> Pipeline
            </NavLink>
            <NavLink class="nav-item" href="/orchestration">
                <span class="nav-ic">🕸</span> Workflow
            </NavLink>

            <div class="nav-section">Config</div>
            <NavLink class="nav-item" href="/settings">
                <span class="nav-ic">⚙</span> Settings
            </NavLink>
        </nav>

        <div class="shell-foot">
            <span>v1.0 · open source</span>
        </div>
    </aside>

    <div class="shell-pane">

        <!-- Top menu bar (File / Edit / View / Tools / Help) -->
        <div class="menubar">
            <span class="menu-item">File</span>
            <span class="menu-item">Edit</span>
            <span class="menu-item" @onclick="ToggleTheme" title="Toggle theme">View</span>
            <span class="menu-item">Tools</span>
            <span class="menu-item">Help</span>
            <div class="menubar-spacer"></div>
            <button class="theme-btn" @onclick="ToggleTheme" title="Toggle theme">
                @(_theme == "light" ? "🌙" : "☀")
            </button>
        </div>

        <!-- Toolbar (icon strip) -->
        <div class="toolbar-strip">
            <button class="tbtn" title="New" @onclick="@(() => Nav.NavigateTo("/orchestration"))">⊕ New</button>
            <button class="tbtn" title="Pipeline" @onclick="@(() => Nav.NavigateTo("/"))">▶ Run</button>
            <span class="tbtn-sep"></span>
            <button class="tbtn" title="Settings" @onclick="@(() => Nav.NavigateTo("/settings"))">⚙ Config</button>
            <span class="tbtn-sep"></span>
            <span class="tbtn-lbl">Path:</span>
            <span class="urlbar">@CurrentPath</span>
        </div>

        <main class="shell-main">
            @Body
        </main>

        <!-- Bottom status bar -->
        <footer class="statusbar">
            <span>Ready</span>
            <span class="sb-sep"></span>
            <span><span class="sb-dot ok"></span> Live · Anthropic + Azure</span>
            <span class="sb-sep"></span>
            <span>NMax 3</span>
            <span class="sb-spacer"></span>
            <span>v1.0 · agentic-sdlc-net</span>
        </footer>
    </div>

</div>

@code {
    [Inject] private NavigationManager Nav { get; set; } = default!;

    private string _theme = "light";

    private string CurrentPath => new Uri(Nav.Uri).AbsolutePath;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _theme = await JS.InvokeAsync<string>("agenticTheme.get");
            StateHasChanged();
        }
    }

    private async Task ToggleTheme()
        => _theme = await JS.InvokeAsync<string>("agenticTheme.toggle");
}
