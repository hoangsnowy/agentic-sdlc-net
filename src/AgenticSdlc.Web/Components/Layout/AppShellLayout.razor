@inherits LayoutComponentBase
@inject Microsoft.JSInterop.IJSRuntime JS
@inject NavigationManager Nav

<LoginOverlay />

<TopBar />

<div class="shell shell-deskmode">
    <div class="shell-pane">
        <main class="shell-main">
            @Body
        </main>

        @* All open desktop-app windows render here on top of the desktop. *@
        <WindowHost />

        <Taskbar StartOpen="_startOpen" OnToggleStart="ToggleStart" />
    </div>
</div>

@* ===== Cascading Start menu (anchored to taskbar, opens upward) ===== *@
@if (_startOpen)
{
    <div class="start-menu-backdrop" @onclick="CloseStart"></div>
    <div class="start-menu cascading" @onclick:stopPropagation="true">
        <div class="sm-header">
            <div class="sm-brand-mark">◆</div>
            <div>
                <div class="sm-brand-title">AgentOS</div>
                <div class="sm-brand-sub">v1.0 · open source</div>
            </div>
        </div>

        <div class="sm-panes">
            <div class="sm-cats">
                <div class="sm-cat @(_cat == "apps" ? "active" : "")" @onmouseenter="@(() => _cat = "apps")">
                    <span class="sm-ic">📱</span> Apps <span class="sm-arrow">▸</span>
                </div>
                <div class="sm-cat @(_cat == "tools" ? "active" : "")" @onmouseenter="@(() => _cat = "tools")">
                    <span class="sm-ic">🔧</span> Tools <span class="sm-arrow">▸</span>
                </div>
                <div class="sm-cat @(_cat == "help" ? "active" : "")" @onmouseenter="@(() => _cat = "help")">
                    <span class="sm-ic">❔</span> Help <span class="sm-arrow">▸</span>
                </div>
                <div class="sm-cat @(_cat == "session" ? "active" : "")" @onmouseenter="@(() => _cat = "session")">
                    <span class="sm-ic">⏻</span> Session <span class="sm-arrow">▸</span>
                </div>
            </div>

            <div class="sm-items">
                @switch (_cat)
                {
                    case "apps":
                        <button class="sm-item" @onclick="@(() => OpenApp("pipeline", "Pipeline", "▶"))"><span class="sm-ic">▶</span> Pipeline <span class="sm-hint">Ctrl+1</span></button>
                        <button class="sm-item" @onclick="@(() => OpenApp("workflow", "Workflow", "🕸", 1080, 660))"><span class="sm-ic">🕸</span> Workflow <span class="sm-hint">Ctrl+2</span></button>
                        <button class="sm-item" @onclick="@(() => OpenApp("settings", "Settings", "⚙", 720, 600))"><span class="sm-ic">⚙</span> Settings <span class="sm-hint">Ctrl+,</span></button>
                        break;
                    case "tools":
                        <button class="sm-item" @onclick="DemoToast"><span class="sm-ic">🔔</span> Test notification</button>
                        <button class="sm-item" @onclick="@(() => OpenApp("pipeline", "Pipeline", "▶"))"><span class="sm-ic">🔨</span> Verify build</button>
                        <button class="sm-item" @onclick="@(() => OpenApp("pipeline", "Pipeline", "▶"))"><span class="sm-ic">🚀</span> Open PR</button>
                        break;
                    case "help":
                        <button class="sm-item" @onclick="ShowAbout"><span class="sm-ic">ℹ</span> About</button>
                        <a class="sm-item" href="https://github.com/hoangsnowy/agentic-sdlc-net" target="_blank" @onclick="CloseStart"><span class="sm-ic">↗</span> GitHub</a>
                        break;
                    case "session":
                        <button class="sm-item" @onclick="LockSession"><span class="sm-ic">🔒</span> Lock</button>
                        <button class="sm-item sm-danger" @onclick="SignOut"><span class="sm-ic">⏻</span> Sign out</button>
                        break;
                }
            </div>
        </div>
    </div>
}

@* ===== About dialog ===== *@
<Dialog Show="_aboutOpen" Title="About — AgentOS" Width="440" OnClose="@(() => _aboutOpen = false)">
    <ChildContent>
        <h3 class="about-h">AgentOS</h3>
        <p class="about-tag">A .NET multi-agent AI framework for the software development lifecycle.</p>
        <table class="about-tbl">
            <tr><th>Version</th><td>1.0</td></tr>
            <tr><th>Runtime</th><td>.NET 10</td></tr>
            <tr><th>License</th><td>MIT</td></tr>
            <tr><th>Source</th><td><a href="https://github.com/hoangsnowy/agentic-sdlc-net" target="_blank">github.com/hoangsnowy/agentic-sdlc-net</a></td></tr>
        </table>
    </ChildContent>
    <Footer>
        <Btn OnClick="@(() => _aboutOpen = false)">Close</Btn>
    </Footer>
</Dialog>

<ToastHost />

@code {
    [Inject] private AgenticSdlc.Web.Services.ToastService Toasts { get; set; } = default!;
    [Inject] private AgenticSdlc.Web.Services.WindowManagerService WM { get; set; } = default!;

    private bool _startOpen;
    private bool _aboutOpen;
    private string _cat = "apps";

    private void ToggleStart()
    {
        _startOpen = !_startOpen;
        if (_startOpen) { _cat = "apps"; }
    }
    private void CloseStart() => _startOpen = false;

    private void OpenApp(string key, string title, string icon, int w = 920, int h = 620)
    {
        WM.OpenApp(key, title, icon, w, h);
        _startOpen = false;
    }

    private void ShowAbout()
    {
        _aboutOpen = true;
        _startOpen = false;
    }

    private void DemoToast()
    {
        Toasts.Show("Notifications", "Toast service is wired and ready.", AgenticSdlc.Web.Services.ToastKind.Ok);
        _startOpen = false;
    }

    private async Task LockSession()
    {
        await JS.InvokeVoidAsync("localStorage.removeItem", "agentic-signed-in");
        Nav.NavigateTo(Nav.Uri, forceLoad: true);
    }

    private async Task SignOut()
    {
        await JS.InvokeVoidAsync("localStorage.removeItem", "agentic-signed-in");
        Toasts.Show("Signed out", "Session cleared. Refresh to sign in again.", AgenticSdlc.Web.Services.ToastKind.Info);
        _startOpen = false;
    }
}
