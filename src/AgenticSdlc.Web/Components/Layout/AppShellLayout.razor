@inherits LayoutComponentBase
@inject Microsoft.JSInterop.IJSRuntime JS
@inject NavigationManager Nav

<LoginOverlay />

<div class="shell">

    <aside class="shell-sidebar">
        <div class="shell-brand">
            <span class="brand-mark">◆</span>
            <div class="brand-text">
                <div class="brand-title">Agentic SDLC</div>
                <div class="brand-sub">Multi-agent framework</div>
            </div>
        </div>

        <nav class="shell-nav">
            <div class="nav-section">Workspace</div>
            <NavLink class="nav-item" Match="NavLinkMatch.All" href="/">
                <span class="nav-ic">🖥</span> Desktop
            </NavLink>
            <NavLink class="nav-item" href="/pipeline">
                <span class="nav-ic">▶</span> Pipeline
            </NavLink>
            <NavLink class="nav-item" href="/orchestration">
                <span class="nav-ic">🕸</span> Workflow
            </NavLink>

            <div class="nav-section">Config</div>
            <NavLink class="nav-item" href="/settings">
                <span class="nav-ic">⚙</span> Settings
            </NavLink>
        </nav>

        <div class="shell-foot">
            <span>v1.0 · open source</span>
        </div>
    </aside>

    <div class="shell-pane">

        @* Toolbar with path indicator + nav buttons *@
        <div class="toolbar-strip">
            <button class="tbtn" title="Desktop" @onclick="@(() => Nav.NavigateTo("/"))">🖥 Home</button>
            <button class="tbtn" title="Run pipeline" @onclick="@(() => Nav.NavigateTo("/pipeline"))">▶ Pipeline</button>
            <button class="tbtn" title="Workflow editor" @onclick="@(() => Nav.NavigateTo("/orchestration"))">🕸 Workflow</button>
            <span class="tbtn-sep"></span>
            <button class="tbtn" title="Settings" @onclick="@(() => Nav.NavigateTo("/settings"))">⚙ Config</button>
            <span class="tbtn-sep"></span>
            <span class="tbtn-lbl">Path:</span>
            <span class="urlbar">@CurrentPath</span>
        </div>

        <main class="shell-main">
            @Body
        </main>

        @* Bottom taskbar (KDE / Windows style) *@
        <Taskbar StartOpen="_startOpen"
                 OnToggleStart="ToggleStart"
                 OnToggleTheme="ToggleTheme"
                 Theme="_theme" />
    </div>

</div>

@* ===== Cascading Start menu (anchored to taskbar, opens upward) ===== *@
@if (_startOpen)
{
    <div class="start-menu-backdrop" @onclick="CloseStart"></div>
    <div class="start-menu cascading" @onclick:stopPropagation="true">
        <div class="sm-header">
            <div class="sm-brand-mark">◆</div>
            <div>
                <div class="sm-brand-title">Agentic SDLC</div>
                <div class="sm-brand-sub">v1.0 · open source</div>
            </div>
        </div>

        <div class="sm-panes">
            <div class="sm-cats">
                <div class="sm-cat @(_cat == "apps" ? "active" : "")" @onmouseenter="@(() => _cat = "apps")">
                    <span class="sm-ic">📱</span> Apps <span class="sm-arrow">▸</span>
                </div>
                <div class="sm-cat @(_cat == "tools" ? "active" : "")" @onmouseenter="@(() => _cat = "tools")">
                    <span class="sm-ic">🔧</span> Tools <span class="sm-arrow">▸</span>
                </div>
                <div class="sm-cat @(_cat == "help" ? "active" : "")" @onmouseenter="@(() => _cat = "help")">
                    <span class="sm-ic">❔</span> Help <span class="sm-arrow">▸</span>
                </div>
                <div class="sm-cat @(_cat == "session" ? "active" : "")" @onmouseenter="@(() => _cat = "session")">
                    <span class="sm-ic">⏻</span> Session <span class="sm-arrow">▸</span>
                </div>
            </div>

            <div class="sm-items">
                @switch (_cat)
                {
                    case "apps":
                        <a class="sm-item" href="/" @onclick="CloseStart"><span class="sm-ic">🖥</span> Desktop <span class="sm-hint">Ctrl+0</span></a>
                        <a class="sm-item" href="/pipeline" @onclick="CloseStart"><span class="sm-ic">▶</span> Pipeline <span class="sm-hint">Ctrl+1</span></a>
                        <a class="sm-item" href="/orchestration" @onclick="CloseStart"><span class="sm-ic">🕸</span> Workflow <span class="sm-hint">Ctrl+2</span></a>
                        <a class="sm-item" href="/settings" @onclick="CloseStart"><span class="sm-ic">⚙</span> Settings <span class="sm-hint">Ctrl+,</span></a>
                        break;
                    case "tools":
                        <button class="sm-item" @onclick="DemoToast"><span class="sm-ic">🔔</span> Test notification</button>
                        <a class="sm-item" href="/pipeline" @onclick="CloseStart"><span class="sm-ic">🔨</span> Verify build</a>
                        <a class="sm-item" href="/pipeline" @onclick="CloseStart"><span class="sm-ic">🚀</span> Open PR</a>
                        break;
                    case "help":
                        <button class="sm-item" @onclick="ShowAbout"><span class="sm-ic">ℹ</span> About</button>
                        <a class="sm-item" href="https://github.com/hoangsnowy/agentic-sdlc-net" target="_blank" @onclick="CloseStart"><span class="sm-ic">↗</span> GitHub</a>
                        break;
                    case "session":
                        <button class="sm-item" @onclick="LockSession"><span class="sm-ic">🔒</span> Lock</button>
                        <button class="sm-item sm-danger" @onclick="SignOut"><span class="sm-ic">⏻</span> Sign out</button>
                        break;
                }
            </div>
        </div>
    </div>
}

@* ===== About dialog ===== *@
<Dialog Show="_aboutOpen" Title="About — Agentic SDLC" Width="440" OnClose="@(() => _aboutOpen = false)">
    <ChildContent>
        <h3 class="about-h">Agentic SDLC</h3>
        <p class="about-tag">A .NET multi-agent AI framework for the software development lifecycle.</p>
        <table class="about-tbl">
            <tr><th>Version</th><td>1.0</td></tr>
            <tr><th>Runtime</th><td>.NET 10</td></tr>
            <tr><th>License</th><td>MIT</td></tr>
            <tr><th>Source</th><td><a href="https://github.com/hoangsnowy/agentic-sdlc-net" target="_blank">github.com/hoangsnowy/agentic-sdlc-net</a></td></tr>
        </table>
    </ChildContent>
    <Footer>
        <Btn OnClick="@(() => _aboutOpen = false)">Close</Btn>
    </Footer>
</Dialog>

@* ===== Toast notifications ===== *@
<ToastHost />

@code {
    [Inject] private AgenticSdlc.Web.Services.ToastService Toasts { get; set; } = default!;

    private string _theme = "light";
    private bool _startOpen;
    private bool _aboutOpen;
    private string _cat = "apps";

    private string CurrentPath => new Uri(Nav.Uri).AbsolutePath;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _theme = await JS.InvokeAsync<string>("agenticTheme.get");
            StateHasChanged();
        }
    }

    private async Task ToggleTheme()
        => _theme = await JS.InvokeAsync<string>("agenticTheme.toggle");

    private void ToggleStart()
    {
        _startOpen = !_startOpen;
        if (_startOpen) { _cat = "apps"; }
    }
    private void CloseStart() => _startOpen = false;

    private void ShowAbout()
    {
        _aboutOpen = true;
        _startOpen = false;
    }

    private void DemoToast()
    {
        Toasts.Show("Notifications", "Toast service is wired and ready.", AgenticSdlc.Web.Services.ToastKind.Ok);
        _startOpen = false;
    }

    private async Task LockSession()
    {
        await JS.InvokeVoidAsync("localStorage.removeItem", "agentic-signed-in");
        Nav.NavigateTo(Nav.Uri, forceLoad: true);
    }

    private async Task SignOut()
    {
        await JS.InvokeVoidAsync("localStorage.removeItem", "agentic-signed-in");
        Toasts.Show("Signed out", "Session cleared. Refresh to sign in again.", AgenticSdlc.Web.Services.ToastKind.Info);
        _startOpen = false;
    }
}
