@* Phase 7b — Widget that renders a single Synapse-style node: card colored by type, in/out, routes, max Nx, 4 ports. *@
@using AgenticSdlc.Web.Orchestrations
@using Blazor.Diagrams.Core.Models
@using Blazor.Diagrams.Components.Renderers

<div class="step-node cat-@CatClass run-@RunClass @(Node.Selected ? "is-selected" : "")">
    <div class="sn-head">
        <span class="sn-ico">@Icon</span>
        <span class="sn-title">@Data.Title</span>
        @if (Data.IsStart)
        {
            <span class="sn-start">START</span>
        }
        <button class="sn-edit" @onclick="@(() => Node.RequestEdit?.Invoke())" @onclick:stopPropagation="true" title="Edit">✎</button>
    </div>

    <div class="sn-body">
        <div class="sn-type">@TypeLabel</div>
        @if (!string.IsNullOrWhiteSpace(Data.Description))
        {
            <div class="sn-desc">@Data.Description</div>
        }
        @if (!string.IsNullOrWhiteSpace(Data.Input))
        {
            <div class="sn-io"><span class="k">in</span> @Data.Input</div>
        }
        @if (!string.IsNullOrWhiteSpace(Data.Output))
        {
            <div class="sn-io"><span class="k">out</span> @Data.Output</div>
        }
        @if (Data.Routes.Count > 0)
        {
            <div class="sn-routes">@Data.Routes.Count routes: @string.Join(", ", Data.Routes)</div>
        }
        @if (Data.MaxIterations > 0)
        {
            <div class="sn-max">max @(Data.MaxIterations)x</div>
        }
        @if (!string.IsNullOrWhiteSpace(Node.RunMeta))
        {
            <div class="sn-meta">@Node.RunMeta</div>
        }
    </div>

    <PortRenderer Port="Node.GetPort(PortAlignment.Left)" Class="sn-port sn-port-l" />
    <PortRenderer Port="Node.GetPort(PortAlignment.Right)" Class="sn-port sn-port-r" />
    <PortRenderer Port="Node.GetPort(PortAlignment.Top)" Class="sn-port sn-port-t" />
    <PortRenderer Port="Node.GetPort(PortAlignment.Bottom)" Class="sn-port sn-port-b" />
</div>

@code {
    /// <summary>The node being rendered (Z.Blazor.Diagrams injects it via RegisterComponent).</summary>
    [Parameter] public StepNodeModel Node { get; set; } = null!;

    private GraphNode Data => Node.Data;

    private string CatClass => Data.Category switch
    {
        StepCategory.Agent => "agent",
        StepCategory.Evaluator => "evaluator",
        StepCategory.Human => "human",
        StepCategory.Llm => "llm",
        StepCategory.Terminal => "terminal",
        _ => "logic",
    };

    private string RunClass => Node.RunState switch
    {
        NodeRunState.Running => "running",
        NodeRunState.Done => "done",
        NodeRunState.Failed => "failed",
        _ => "idle",
    };

    private string Icon => Data.Category switch
    {
        StepCategory.Agent => "◆",
        StepCategory.Evaluator => "◈",
        StepCategory.Human => "◉",
        StepCategory.Llm => "λ",
        StepCategory.Terminal => "■",
        _ => "▣",
    };

    private string TypeLabel => Data.Type switch
    {
        StepType.Agent => "AGENT",
        StepType.Evaluator => "EVALUATOR",
        StepType.Human => "HUMAN",
        StepType.Llm => "LLM",
        StepType.End => "END",
        _ => Data.Type.ToString().ToUpperInvariant(),
    };
}
