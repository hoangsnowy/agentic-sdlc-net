# Multi-stage Dockerfile cho AgenticSdlc.Web (Blazor Server — Agent Studio UI).
# Build: docker build -f Dockerfile.web -t agenticsdlc-web:dev .
# Engine (5 agent + gateway) chạy in-process qua reference Infrastructure.

# ---- Stage 1: build ----
FROM mcr.microsoft.com/dotnet/sdk:10.0 AS build
WORKDIR /src

# Copy csproj + restore (cache layer) — chỉ graph của Web: Web → Infrastructure → Application → Domain.
COPY global.json Directory.Build.props ./
COPY AgenticSdlc.sln ./
COPY src/AgenticSdlc.Domain/AgenticSdlc.Domain.csproj            src/AgenticSdlc.Domain/
COPY src/AgenticSdlc.Application/AgenticSdlc.Application.csproj  src/AgenticSdlc.Application/
COPY src/AgenticSdlc.Infrastructure/AgenticSdlc.Infrastructure.csproj src/AgenticSdlc.Infrastructure/
COPY src/AgenticSdlc.Web/AgenticSdlc.Web.csproj                  src/AgenticSdlc.Web/
RUN dotnet restore src/AgenticSdlc.Web/AgenticSdlc.Web.csproj

# Copy source + publish Release
COPY . .
RUN dotnet publish src/AgenticSdlc.Web/AgenticSdlc.Web.csproj \
    -c Release \
    -o /app/publish \
    --no-restore \
    /p:UseAppHost=false

# ---- Stage 2: runtime ----
FROM mcr.microsoft.com/dotnet/aspnet:10.0 AS runtime
WORKDIR /app

# Base image aspnet:10.0 đã có sẵn non-root user 'app' (uid 1654).
COPY --from=build --chown=app:app /app/publish .
USER app

ENV ASPNETCORE_URLS=http://+:8080 \
    ASPNETCORE_ENVIRONMENT=Production \
    DOTNET_RUNNING_IN_CONTAINER=true \
    DOTNET_USE_POLLING_FILE_WATCHER=false

EXPOSE 8080

HEALTHCHECK --interval=30s --timeout=5s --start-period=20s --retries=3 \
    CMD wget --quiet --tries=1 --spider http://localhost:8080/health || exit 1

ENTRYPOINT ["dotnet", "AgenticSdlc.Web.dll"]
