<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <RootNamespace>AgenticSdlc.Tests</RootNamespace>
    <AssemblyName>AgenticSdlc.Tests</AssemblyName>
    <IsPackable>false</IsPackable>
    <IsTestProject>true</IsTestProject>
    <!-- Test method names theo convention MethodName_StateUnderTest_ExpectedBehavior
         (Microsoft khuyến nghị cho unit test) — tự nhiên có underscore.
         Tắt CA1707 cho project test. -->
    <NoWarn>$(NoWarn);CA1707</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\src\AgenticSdlc.Domain\AgenticSdlc.Domain.csproj" />
    <ProjectReference Include="..\..\src\AgenticSdlc.Application\AgenticSdlc.Application.csproj" />
    <ProjectReference Include="..\..\src\AgenticSdlc.Infrastructure\AgenticSdlc.Infrastructure.csproj" />
  </ItemGroup>

  <ItemGroup>
    <!-- Test runner -->
    <PackageReference Include="JsonSchema.Net" Version="7.*" />
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.13.0" />
    <PackageReference Include="xunit.v3" Version="1.1.0" />
    <PackageReference Include="xunit.runner.visualstudio" Version="3.0.2" />

    <!-- Mocking + assertions: dùng Shouldly (OSS) thay FluentAssertions v8 (đã commercial) -->
    <PackageReference Include="NSubstitute" Version="5.3.0" />
    <PackageReference Include="Shouldly" Version="4.3.0" />

    <!-- Persistence test: EF Core InMemory (jsonb column type bị bỏ qua — đủ test repo logic) -->
    <PackageReference Include="Microsoft.EntityFrameworkCore.InMemory" Version="10.0.0" />

    <!-- Coverage -->
    <PackageReference Include="coverlet.collector" Version="6.0.4">
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
      <PrivateAssets>all</PrivateAssets>
    </PackageReference>
  </ItemGroup>

</Project>
